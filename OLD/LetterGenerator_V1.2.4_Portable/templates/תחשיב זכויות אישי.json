{
  "template_name": "תחשיב זכויות אישי",
  "template_file": "תחשיב זכויות אישי.docx",
  "excel_columns": {
    "MEMBER_CODE": "C",
    "LAST_NAME": "E",
    "FIRST_NAME": "F",
    "H": "H",
    "I": "I",
    "J": "J",
    "L": "L",
    "M": "M",
    "O": "O",
    "P": "P",
    "R": "R",
    "BANK_ACCOUNT": "S",
    "T": "T"
  },
  "computed_fields": {
    "FULL_NAME": "{LAST_NAME} {FIRST_NAME}"
  },
  "conditions": {
    "show_DEATH_SECTION": "L > 0",
    "show_WORK_GRANT_SECTION": "O > 0",
    "show_NEW_MEMBER_SECTION": "T == 'נקלט.ת'",
    "show_BUILDING_DEBT_SECTION": "R != ''"
  },
  "output_filename": {
    "pattern": "{MEMBER_CODE} {LAST_NAME} {FIRST_NAME} {template_name}.pdf"
  },
  "signature_field": {
    "field_name": "MemberSignature",
    "page": "last",
    "width": 225,
    "height": 42,
    "margin_bottom": 95,
    "margin_left": 50,
    "anchor_text": "חתימה (שדה לחתימה דיגיטלית)"
  },
  "date_field": {
    "field_name": "SignDateEntry",
    "page": "last",
    "width": 130,
    "height": 42
  },
  "validation": {
    "required_excel_columns": [
      "C",
      "E",
      "F",
      "H",
      "I",
      "J",
      "L",
      "M",
      "O",
      "P",
      "S"
    ],
    "required_template_variables": [
      "FULL_NAME",
      "TODAY",
      "P",
      "BANK_ACCOUNT"
    ],
    "required_row_fields": [
      "MEMBER_CODE",
      "LAST_NAME",
      "FIRST_NAME",
      "BANK_ACCOUNT",
      "P"
    ],
    "numeric_row_fields": [
      "H",
      "I",
      "J",
      "L",
      "M",
      "O",
      "P"
    ]
  }
}
